{
  "name": "huda-nuclear-ai",
  "version": "1.0.0",
  "description": "HUDA Nuclear Autonomous Engineering Platform",
  "main": "main.js",
  "author": "HUDA",
  "scripts": {
    "start": "npx electron .",
    "build-linux": "npx electron-builder --linux",
    "build-win": "npx electron-builder --win"
  },
  "build": {
    "appId": "com.huda.nuclear.ai",
    "productName": "HUDA Nuclear AI",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "debug": "^4.4.3"
  }
}
